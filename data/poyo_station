#!/bin/bash
# 🌸 PINK COSMIC STATION: MASTER ENGINE | avsn17

# ─── 1. SILENT STARTUP ───
pkill -f kirby_desktop.py
pkill -f Xvfb
echo "active" > music_signal.txt
git add music_signal.txt &>/dev/null
git commit -m "avsn17 Session Start" &>/dev/null
git push origin main &>/dev/null &
xvfb-run -a python3 kirby_desktop.py &>/dev/null &

# ─── 2. VIBRANT CONFIG ───
URLS=("https://youtu.be/5XJNg8x89yo" "https://youtu.be/QNJL6nfu__Q" "https://youtu.be/AmXdpVnJwt8" "https://youtu.be/ukgluvJpL4U" "https://youtu.be/9-HhuD6D_3U")
FACES=("(> ^.^)>" "<(^.^ <)" "(◕‿◕)っ" "٩(◕‿◕｡)۶" "(ง •_•)ง" "(－_－)zZ")
MOODS=("idle" "working" "done" "sleepy" "hungry")

# THE PINK PALETTE
HOT_PINK='\033[38;5;201m'
DEEP_PINK='\033[38;5;198m'
SOFT_PINK='\033[38;5;218m'
WHITE='\033[97m'
NC='\033[0m' 

play_legend() {
    RAND_URL=${URLS[$RANDOM % ${#URLS[@]}]}
    RAND_MOOD=${MOODS[$RANDOM % ${#MOODS[@]}]}
    RAND_FACE=${FACES[$RANDOM % ${#FACES[@]}]}
    mkdir -p data
    echo "$RAND_MOOD" > data/kirby_mood.txt
    python3 -c "import webbrowser; webbrowser.open('$RAND_URL')" &>/dev/null &
    echo -e "      ${HOT_PINK}✨ ${WHITE}Vibe: ${SOFT_PINK}$RAND_MOOD ${WHITE}$RAND_FACE ${HOT_PINK}✨${NC}"
}

# ─── 3. EXIT HANDLER ───
trap 'echo "paused" > music_signal.txt; git add music_signal.txt &>/dev/null; git commit -m "End Session" &>/dev/null; git push origin main &>/dev/null; pkill -f kirby_desktop.py; clear; echo -e "${DEEP_PINK}🌸 Bye avsn17! Stay pink! ✨${NC}"; exit' SIGINT

# ─── 4. THE HYPER-PINK INTERFACE ───
clear
echo -e "${HOT_PINK}"
echo "    ██████╗  ██████╗ ██╗   ██╗ ██████╗ "
echo "    ██╔══██╗██╔═══██╗╚██╗ ██╔╝██╔═══██╗"
echo "    ██████╔╝██║   ██║ ╚████╔╝ ██║   ██║"
echo "    ██╔═══╝ ██║   ██║  ╚██╔╝  ██║   ██║"
echo "    ██║     ╚██████╔╝   ██║   ╚██████╔╝"
echo "    ╚═╝      ╚═════╝    ╚═╝    ╚═════╝ "
echo -e "    ${DEEP_PINK}────────────────────────────────────────────${NC}"
echo -e "    ${WHITE}Welcome back, ${HOT_PINK}avsn17${WHITE}! Vibe check?${NC}"
echo -e "    ${SOFT_PINK}next ${WHITE}✦ ${SOFT_PINK}save ${WHITE}✦ ${SOFT_PINK}q${NC}"
echo -e "    ${DEEP_PINK}────────────────────────────────────────────${NC}"

play_legend

while true; do
    echo -ne "\n    ${HOT_PINK}avsn17 ${WHITE}${FACES[$RANDOM % ${#FACES[@]}]} ${DEEP_PINK}» ${NC}"
    read -r USER_INPUT
    
    case "$USER_INPUT" in
        q|exit)
            kill -INT $$
            ;;
        save)
            echo -e "    ${HOT_PINK}🪄  ${WHITE}Cleaning ghosts...${NC}"
            find . -type d -name "__pycache__" -exec rm -rf {} +
            echo -ne "    ${SOFT_PINK}Message ${DEEP_PINK}› ${WHITE}"
            read -r MSG
            if [ -z "$MSG" ]; then MSG="Cleaned ghosts for avsn17"; fi
            git add . &>/dev/null
            git commit -m "$MSG" &>/dev/null
            git push origin main &>/dev/null
            echo -e "    ${HOT_PINK}✨ ${WHITE}Cloud Synced! Opening logs...${NC}"
            python3 -c "import webbrowser; webbrowser.open('https://github.com/avsn17/kirbs.pomodoro')"
            ;;
        r|next)
            play_legend
            ;;
        *)
            eval "$USER_INPUT"
            ;;
    esac
done
