#!/bin/bash
echo "    🧹 Clearing ghosts..."
find . -type d -name "__pycache__" -exec rm -rf {} +
echo "    ☁️ Syncing to GitHub..."
git add .
git commit -m "Station Auto-Save: $(date +'%Y-%m-%d %H:%M')"
git push origin kirbs
echo "    🚀 Poyo Complete! Opening Cloud Log..."
python3 -m webbrowser "https://github.com/avsn17/kirbs.pomodoro"
