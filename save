#!/bin/bash

# ─── CLEAN STATION LOGIC ───────────────────────────────────────
echo "🧹 Clearing ghosts..."

# Remove __pycache__ folders and .pyc files
find . -type d -name "__pycache__" -exec rm -rf {} +
find . -type f -name "*.pyc" -delete

echo "📝 Updating requirements.txt..."
pip freeze > requirements.txt

# ─── GIT PUSH LOGIC ───────────────────────────────────────────
echo "☁️ Pushing to cloud [branch: kirbs]..."

git add .

# Check if there are changes to commit
if git diff-index --quiet HEAD --; then
    echo "✨ No changes to save. Station is already clean!"
else
    git commit -m "Station Save: $(date +'%Y-%m-%d %H:%M') | poyo!"
    git push origin kirbs
    echo "🚀 Poyo Complete! Everything is in the cloud."
fi
